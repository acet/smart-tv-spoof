# Network interface the TV is on (e.g. eth0, enp3s0)
HOST_INTERFACE=eth0

# LAN subnet and gateway
LAN_SUBNET=10.0.0.0/24
LAN_GATEWAY=10.0.0.1

# IP for NextDNS to listen on (your server's LAN IP)
DNS_LISTEN_IP=10.0.0.2

# Free LAN IP for mitmproxy (must not be in use)
MITMPROXY_IP=10.0.0.3

# NextDNS profile ID (from your NextDNS dashboard)
NEXTDNS_PROFILE_ID=abc123